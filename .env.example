# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sd4a_user:sd4a_password@localhost:5432/sd4a_portal

# ─── AUTH (Auth.js) ──────────────────────────────────────────────────────────
NEXTAUTH_SECRET=change_me_generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# ─── GOOGLE DRIVE API ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_FOLDER_ID=              # ID de la carpeta raíz "SD4A PROYECTOS"
GOOGLE_SERVICE_ACCOUNT_KEY=          # JSON de la service account (base64)

# ─── WOMPI ───────────────────────────────────────────────────────────────────
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_WEBHOOK_SECRET=
WOMPI_ENV=sandbox                    # sandbox | production

# ─── AUTODESK PLATFORM SERVICES ──────────────────────────────────────────────
APS_CLIENT_ID=
APS_CLIENT_SECRET=

# ─── API INTERNAL ────────────────────────────────────────────────────────────
API_URL=http://localhost:8000
API_SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ─── MISC ────────────────────────────────────────────────────────────────────
NODE_ENV=development
